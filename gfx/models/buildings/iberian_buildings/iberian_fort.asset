pdxmesh = {
	name = "iberian_fort_mesh"
	file = "iberian_fort.mesh"

	meshsettings = {
		name = "iberian_fortShape"
		index = 0
		texture_diffuse = "iberian_buildings_01_diffuse.dds"
		texture_normal = "iberian_buildings_01_normals.dds"
		texture_specular = "indian_buildings_01_properties.dds"
		shader = "standard_snow"
		shader_file = "gfx/FX/pdxmesh.shader"
	}

	meshsettings = {
		name = "iberian_fort_decalShape"
		index = 0
		texture_diffuse = "stone_tiles_diffuse.dds"
		texture_normal = "stone_tiles_normal.dds"
		texture_specular = "stone_tiles_material.dds"
		texture = { file = "iberian_fort_mask.dds" index = 3 }
		shader = "decal_world"
		shader_file = "gfx/FX/pdxmesh_decal.shader"
		subpass = "Decals"
	}
}

entity = {
	name = "iberian_gfx_fort_entity"
	pdxmesh = "iberian_fort_mesh"
	default_state = "default"

	state = {
		name = default
		start_event = { trigger_once = yes sound = { soundeffect = "event:/SFX/Ambience/3DMapEmitters/Military/sfx_amb_3d_military_fort_tribal" } keep_sound = yes }
	}
}
