pdxmesh = {
	name = "thracian_fort_mesh"
	file = "thracian_fort.mesh"

	meshsettings = {
		name = "thracian_fortShape"
		index = 0
		texture_diffuse = "thracian_buildings_diffuse.dds"
		texture_normal = "thracian_buildings_normal.dds"
		texture_specular = "thracian_buildings_properties.dds"
		shader = "standard_snow"
		shader_file = "gfx/FX/pdxmesh.shader"
	}

	meshsettings = {
		name = "thracian_fort_decalShape"
		index = 0
		texture_diffuse = "stone_tiles_diffuse.dds"
		texture_normal = "stone_tiles_normal.dds"
		texture_specular = "stone_tiles_material.dds"
		texture = { file = "hellenistic_fort_mask.dds" index = 3 }
		shader = "decal_world"
		shader_file = "gfx/FX/pdxmesh_decal.shader"
		subpass = "Decals"
	}
}

entity = {
	name = "thracian_gfx_fort_entity"
	pdxmesh = "thracian_fort_mesh"
	default_state = "default"

	state = {
		name = default
		start_event = { trigger_once = yes sound = { soundeffect = "event:/SFX/Ambience/3DMapEmitters/Military/sfx_amb_3d_military_fort_hellenic" } keep_sound = yes }
	}
}