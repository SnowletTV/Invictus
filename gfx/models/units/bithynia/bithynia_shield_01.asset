### LEGION
pdxmesh = {
	name = "bithynia_shield_mesh"
	file = "../boeotian/boeotian_shield.mesh"

	meshsettings = {
		name = "boeotian_shield_Shape"
		index = 0
		texture_diffuse = "bithynia_shield_diffuse.dds"
		texture_normal = "boeotian_shield_normal.dds"
		texture_specular = "boeotian_shield_properties.dds"
		shader = "standard_usercolor"
		shader_file = "gfx/FX/pdxmesh.shader"
	}
}

entity = {
	name = "bithynia_shield_entity"
	pdxmesh = "bithynia_shield_mesh"
}


